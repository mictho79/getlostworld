---
export const prerender = false;
import { COUNTRY_VIBES as VIBES_EN, COUNTRY_DATA as DATA_EN, slugify } from '../lib/countryData.js';
import { getT } from '../i18n/translations';

const lang = 'en' as const;
const t    = getT(lang);

const vibesSrc = VIBES_EN;
const dataSrc  = DATA_EN;

// Build enriched country payload for the globe — always iterate EN keys so new nations are included
const globeData: Record<string, { vibe: string; fact: string; slug: string }> = {};
for (const [name, _vibe] of Object.entries(VIBES_EN as Record<string, string>)) {
  const vibe = (vibesSrc as any)[name] ?? _vibe;
  const d    = (dataSrc  as any)[name] ?? (DATA_EN as any)[name];
  globeData[name] = { vibe, fact: d?.fact ?? '', slug: slugify(name) };
}

// Sorted list for autocomplete
const countryList = Object.keys(globeData).sort().map(n => ({
  name: n,
  slug: globeData[n].slug,
  vibe: globeData[n].vibe,
}));
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
