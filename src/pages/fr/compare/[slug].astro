/* ── Data rows (dr) — label/value inside duo-cards ── */
.dr-list { display: flex; flex-direction: column; gap: 0; }
.dr {
  display: flex; align-items: baseline; justify-content: space-between;
  gap: 8px; padding: 8px 0;
  border-bottom: 0.5px solid rgba(255,255,255,0.05);
  font-size: 12.5px;
}
.dr:last-child { border-bottom: none; padding-bottom: 0; }
.dr--wrap { align-items: flex-start; flex-wrap: wrap; }
.dr-l {
  flex-shrink: 0; color: var(--t3); font-size: 11px;
  text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;
  min-width: 80px;
}
.dr-l--ath { color: rgba(255,200,50,0.6); min-width: 16px; text-align: center; letter-spacing: 0; }
.dr-v { color: var(--t1); text-align: right; line-height: 1.4; }
.dr-pills { display: flex; flex-wrap: wrap; gap: 4px; justify-content: flex-end; }
.pill-sm {
  font-size: 10.5px; padding: 2px 8px; border-radius: 20px;
  background: rgba(255,255,255,0.07); color: var(--t2);
  border: 0.5px solid rgba(255,255,255,0.10);
}
.dr-hdi { font-weight: 700; }
.dr-hdi--high   { color: #69d89a; }
.dr-hdi--medium { color: #ffb74d; }
.dr-hdi--low    { color: #ff7373; }

/* ── Duo cards (Geography, People, Food, Sport) ── */
.duo {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
}
.duo-card {
  padding: 22px 22px 18px;
  background: var(--bg2); border: 0.5px solid var(--bd);
  border-radius: var(--r);
  display: flex; flex-direction: column; gap: 12px;
  transition: border-color .18s;
}
.duo-card:hover { border-color: var(--bd2); }
.duo-head {
  font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; color: var(--dh);
}
.duo-text {
  font-size: 13.5px; line-height: 1.85;
  color: var(--t2); margin: 0; flex: 1;
}
.duo-text strong { color: var(--t1); font-weight: 500; }
.duo-link {
  display: inline-block; font-size: 11.5px;
  color: var(--dl); text-decoration: none;
  letter-spacing: 0.04em;
  transition: opacity .18s;
  margin-top: auto;
  padding-top: 4px;
}
.duo-link:hover { opacity: 0.7; }

/* ── Editorial ── */
.editorial {
  font-family: 'Playfair Display', serif; font-style: italic;
  font-size: 15.5px; line-height: 1.95; color: var(--t2);
  padding: 24px 30px; margin: 0;
  background: var(--bg2);
  border-left: 2px solid;
  border-image: linear-gradient(to bottom, var(--ca), var(--cb)) 1;
  border-radius: 0 var(--r) var(--r) 0;
}

/* ── CTA row ── */
.cta-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.cta-card {
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  padding: 26px 18px; border-radius: var(--r); text-decoration: none;
  text-align: center;
  background: color-mix(in srgb,var(--cc) 5%,var(--bg2));
  border: 0.5px solid color-mix(in srgb,var(--cc) 20%,var(--bd));
  transition: background .2s, border-color .2s, transform .2s;
}
.cta-card:hover {
  background: color-mix(in srgb,var(--cc) 10%,var(--bg2));
  border-color: color-mix(in srgb,var(--cc) 40%,transparent);
  transform: translateY(-2px);
}
.cta-flag { font-size: 44px; line-height: 1; }
.cta-name { font-size: 17px; font-weight: 600; color: var(--t1); font-family: 'Playfair Display', serif; }
.cta-sub  { font-size: 9px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--cc); opacity: 0.8; }
.cta-arr  { font-size: 14px; color: var(--cc); opacity: 0.55; }

/* ── Pills ── */
.pills { display: flex; flex-wrap: wrap; gap: 7px; }
.pill {
  font-size: 12px; color: var(--t3); text-decoration: none;
  padding: 5px 14px; border: 0.5px solid var(--bd);
  border-radius: 20px; background: rgba(255,255,255,0.025);
  white-space: nowrap;
  transition: color .18s, border-color .18s, background .18s;
}
.pill:hover {
  color: var(--t1); border-color: var(--bd2);
  background: rgba(255,255,255,0.06);
}
.pill--sm { font-size: 11px; padding: 4px 11px; }

/* ── Neighbours ── */
.neighbours-section { display: flex; flex-direction: column; gap: 20px; }

/* ── Map CTA ── */
.map-cta { margin-top: 48px; padding-top: 28px; border-top: 0.5px solid rgba(255,255,255,0.05); text-align: center; }
.map-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 12px 26px; border-radius: 28px;
  background: rgba(255,255,255,0.04); border: 0.5px solid var(--bd2);
  font-size: 12.5px; color: var(--t3); text-decoration: none; letter-spacing: 0.04em;
  transition: background .2s, color .2s;
}
.map-btn:hover { background: rgba(255,255,255,0.08); color: var(--t1); }

/* ── Mobile ── */
@media (max-width: 640px) {
  .hero { grid-template-columns: 1fr; gap: 16px; padding: 32px 20px 36px; }
  .hero-vs { order: -1; }
  .hero-globe { display: none; }
  .switcher { grid-template-columns: 1fr; gap: 10px; }
  .sw-swap { margin: 0 auto; }
  .facts-head { display: none; }
  .facts-a, .facts-b, .facts-m { padding: 9px 8px; font-size: 12px; }
  .facts-m { font-size: 7px; }
  .ti-head { display: none; }
  .ti-row { grid-template-columns: 1fr 1fr; gap: 8px; }
  .ti-label { grid-column: 1 / -1; font-size: 11px; }
  .ti-verdicts, .duo, .cta-row { grid-template-columns: 1fr; }
}
</style>

<script>
  const countries: {name:string;slug:string}[] = JSON.parse(document.getElementById('cmp-countries')!.textContent!);

  let slugA = (document.querySelector('.hero-name--a') as HTMLElement)?.closest('.hero-side')?.querySelector<HTMLElement>('.hero-name')?.dataset.slug ?? '';
  let slugB = (document.querySelector('.hero-name--b') as HTMLElement)?.closest('.hero-side')?.querySelector<HTMLElement>('.hero-name')?.dataset.slug ?? '';

  // Read current slugs from URL path: /fr/compare/france-vs-germany/
  const path = window.location.pathname.replace(/\/$/, '');
  const seg  = path.split('/').pop() || '';
  const vsIdx = seg.indexOf('-vs-');
  if (vsIdx > -1) {
    slugA = seg.slice(0, vsIdx);
    slugB = seg.slice(vsIdx + 4);
  }

  function autocomplete(inputEl: HTMLInputElement, dropEl: HTMLElement, onPick: (c:{name:string;slug:string})=>void) {
    let ai = -1;

    const render = (q: string) => {
      dropEl.innerHTML = ''; ai = -1;
      if (!q.trim()) { dropEl.hidden = true; return; }
      const lo = q.toLowerCase();
      const hits = countries
        .filter(c => c.name.toLowerCase().includes(lo))
        .sort((a,b) => {
          const as = a.name.toLowerCase().startsWith(lo), bs = b.name.toLowerCase().startsWith(lo);
          return as === bs ? a.name.localeCompare(b.name) : as ? -1 : 1;
        }).slice(0,8);
      if (!hits.length) { dropEl.hidden = true; return; }
      hits.forEach(c => {
        const d = document.createElement('div');
        d.className = 'ac-opt'; d.dataset.slug = c.slug; d.textContent = c.name;
        d.addEventListener('mousedown', e => { e.preventDefault(); pick(c); });
        dropEl.appendChild(d);
      });
      dropEl.hidden = false;
    };

    const pick = (c:{name:string;slug:string}) => {
      inputEl.value = c.name; dropEl.hidden = true; ai = -1; onPick(c);
    };

    const setActive = (i:number) => {
      dropEl.querySelectorAll<HTMLElement>('.ac-opt').forEach((o,j) => o.classList.toggle('ac-opt--on', j===i));
      ai = i;
    };

    inputEl.addEventListener('input',  () => render(inputEl.value));
    inputEl.addEventListener('focus',  () => { if(inputEl.value) render(inputEl.value); });
    inputEl.addEventListener('blur',   () => setTimeout(() => { dropEl.hidden=true; }, 200));
    inputEl.addEventListener('keydown', e => {
      const opts = dropEl.querySelectorAll<HTMLElement>('.ac-opt');
      if      (e.key==='ArrowDown')            { e.preventDefault(); setActive(Math.min(ai+1,opts.length-1)); }
      else if (e.key==='ArrowUp')              { e.preventDefault(); setActive(Math.max(ai-1,-1)); }
      else if (e.key==='Enter' && ai>=0)       { e.preventDefault(); const c=countries.find(x=>x.slug===opts[ai].dataset.slug); if(c) pick(c); }
      else if (e.key==='Escape')               { dropEl.hidden=true; inputEl.blur(); }
    });

    return { setValue: (name:string) => { inputEl.value = name; } };
  }

  function go() {
    if (slugA && slugB && slugA !== slugB)
      window.location.href = `/fr/compare/${slugA}-vs-${slugB}/`;
  }

  const inputA = document.getElementById('sw-a')      as HTMLInputElement;
  const inputB = document.getElementById('sw-b')      as HTMLInputElement;
  const dropA  = document.getElementById('sw-drop-a') as HTMLElement;
  const dropB  = document.getElementById('sw-drop-b') as HTMLElement;
  const swap   = document.getElementById('sw-swap')   as HTMLButtonElement;

  const acA = autocomplete(inputA, dropA, c => { slugA = c.slug; go(); });
  const acB = autocomplete(inputB, dropB, c => { slugB = c.slug; go(); });

  const cA = countries.find(c=>c.slug===slugA), cB = countries.find(c=>c.slug===slugB);
  if (cA) acA.setValue(cA.name);
  if (cB) acB.setValue(cB.name);

  swap.addEventListener('click', () => {
    [slugA, slugB] = [slugB, slugA];
    const a = countries.find(c=>c.slug===slugA), b = countries.find(c=>c.slug===slugB);
    if(a) acA.setValue(a.name); if(b) acB.setValue(b.name);
    go();
  });
</script>
