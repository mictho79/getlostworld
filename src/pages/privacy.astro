---
import Base from '../layouts/Base.astro';
---
<Base
  title="Privacy Policy — TerraLenses"
  description="Privacy policy for TerraLenses. We use Plausible Analytics, a privacy-friendly tool that collects no personal data."
  lang="en"
  hreflangEn="https://terralenses.com/privacy/"
  hreflangFr="https://terralenses.com/fr/privacy/"
>
  <main id="main-content" style="max-width:760px;margin:0 auto;padding:64px 24px 80px;">
    <h1 style="font-family:'Playfair Display',serif;font-size:36px;font-weight:700;color:#fff;margin-bottom:8px;">Privacy Policy</h1>
    <p style="color:rgba(255,255,255,0.35);font-size:13px;margin-bottom:48px;">Last updated: March 2026</p>

    <section style="margin-bottom:36px;">
      <h2 style="font-size:18px;font-weight:600;color:rgba(147,197,253,0.9);margin-bottom:12px;">No Personal Data Collected</h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.55);line-height:1.75;">
        TerraLenses does not collect, store or share any personally identifiable information. No registration, login or account is required to use the site.
      </p>
    </section>

    <section style="margin-bottom:36px;">
      <h2 style="font-size:18px;font-weight:600;color:rgba(147,197,253,0.9);margin-bottom:12px;">Analytics</h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.55);line-height:1.75;">
        TerraLenses uses <a href="https://plausible.io" rel="noopener noreferrer" style="color:#60a5fa;">Plausible Analytics</a>, a privacy-friendly, cookieless analytics tool. Plausible does not use cookies, does not collect personal data, and does not track users across sites or devices. No GDPR consent banner is required. Visit <a href="https://plausible.io/data-policy" rel="noopener noreferrer" style="color:#60a5fa;">plausible.io/data-policy</a> for details.
      </p>
    </section>

    <section style="margin-bottom:36px;">
      <h2 style="font-size:18px;font-weight:600;color:rgba(147,197,253,0.9);margin-bottom:12px;">Cookies</h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.55);line-height:1.75;">
        TerraLenses uses a single localStorage entry (<code style="color:rgba(255,255,255,0.7);">lang-choice</code>) to remember your preferred language (English or French) between visits. No third-party cookies are set.
      </p>
    </section>

    <section style="margin-bottom:36px;">
      <h2 style="font-size:18px;font-weight:600;color:rgba(147,197,253,0.9);margin-bottom:12px;">External Resources</h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.55);line-height:1.75;">
        The site loads fonts from Google Fonts and map tiles via Leaflet/unpkg CDN. These services may collect IP addresses and basic request metadata per their own privacy policies.
      </p>
    </section>

    <section style="margin-bottom:36px;">
      <h2 style="font-size:18px;font-weight:600;color:rgba(147,197,253,0.9);margin-bottom:12px;">Contact</h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.55);line-height:1.75;">
        For any privacy-related question, contact us at <a href="mailto:hello@terralenses.com" style="color:#60a5fa;">hello@terralenses.com</a>.
      </p>
    </section>

    <p style="margin-top:48px;">
      <a href="/" style="color:#60a5fa;font-size:14px;text-decoration:none;">← Back to TerraLenses</a>
    </p>
  </main>
</Base>
