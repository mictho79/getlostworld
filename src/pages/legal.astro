---
import Base from '../layouts/Base.astro';
---
<Base
  title="Legal Notice — TerraLenses"
  description="Legal notice and terms of use for TerraLenses, the interactive world atlas."
  lang="en"
  hreflangEn="https://terralenses.com/legal/"
  hreflangFr="https://terralenses.com/fr/legal/"
>
  <main id="main-content" style="max-width:760px;margin:0 auto;padding:64px 24px 80px;">
    <h1 style="font-family:'Playfair Display',serif;font-size:36px;font-weight:700;color:#fff;margin-bottom:8px;">Legal Notice</h1>
    <p style="color:rgba(255,255,255,0.35);font-size:13px;margin-bottom:48px;">Last updated: March 2026</p>

    <section style="margin-bottom:36px;">
      <h2 style="font-size:18px;font-weight:600;color:rgba(147,197,253,0.9);margin-bottom:12px;">Publisher</h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.55);line-height:1.75;">
        TerraLenses is an independent project. For any inquiry, please contact us at
        <a href="mailto:mic.thomas1334@gmail.com" style="color:#60a5fa;">mic.thomas1334@gmail.com</a>.
      </p>
    </section>

    <section style="margin-bottom:36px;">
      <h2 style="font-size:18px;font-weight:600;color:rgba(147,197,253,0.9);margin-bottom:12px;">Purpose</h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.55);line-height:1.75;">
        TerraLenses provides general geographical and cultural information about countries around the world for educational and informational purposes. The data displayed is sourced from publicly available databases (REST Countries API, World Atlas) and may not reflect the most recent political or administrative changes.
      </p>
    </section>

    <section style="margin-bottom:36px;">
      <h2 style="font-size:18px;font-weight:600;color:rgba(147,197,253,0.9);margin-bottom:12px;">Intellectual Property</h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.55);line-height:1.75;">
        The design, code and editorial content of TerraLenses are protected by copyright. Reproduction or distribution of any content without prior written permission is prohibited. Country flag emojis are part of the Unicode standard and are not owned by TerraLenses.
      </p>
    </section>

    <section style="margin-bottom:36px;">
      <h2 style="font-size:18px;font-weight:600;color:rgba(147,197,253,0.9);margin-bottom:12px;">Liability</h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.55);line-height:1.75;">
        TerraLenses makes no warranty regarding the accuracy, completeness or timeliness of the information provided. The site shall not be held liable for any damages arising from the use of the information presented.
      </p>
    </section>

    <p style="margin-top:48px;">
      <a href="/" style="color:#60a5fa;font-size:14px;text-decoration:none;">← Back to TerraLenses</a>
    </p>
  </main>
</Base>
