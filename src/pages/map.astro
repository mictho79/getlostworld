---
export const prerender = false;
import { COUNTRY_DATA as DATA_EN } from '../lib/countryData.js';
import { getT } from '../i18n/translations';

const lang = 'en' as const;
const t = getT(lang);

const highlightParam = Astro.url.searchParams.get('highlight') || '';
const highlightSlugs = highlightParam ? highlightParam.split(',').map((s: string) => s.trim()).filter(Boolean) : [];
const fromParam = Astro.url.searchParams.get('from') || '';
const valuesParam = Astro.url.searchParams.get('values') || '';
const highlightValues = valuesParam ? valuesParam.split('|') : [];

const countryDataSrc: typeof DATA_EN = DATA_EN;

// Extract just the fact field per country for the sidebar
const sidebarFacts: Record<string, string> = {};
for (const [name, data] of Object.entries(countryDataSrc as any)) {
  if ((data as any).fact) sidebarFacts[name] = (data as any).fact;
}
// Name aliases: countries.js uses different keys than countryData.js
const SIDEBAR_ALIASES: Record<string, string> = {
  'United States':     'United States of America',
  'DR Congo':          'Democratic Republic of the Congo',
  'Ivory Coast':       "Côte d'Ivoire",
  'Republic of Congo': 'Republic of the Congo',
  'Cape Verde':        'Cabo Verde',
};
for (const [cjsName, libName] of Object.entries(SIDEBAR_ALIASES)) {
  if (sidebarFacts[libName]) sidebarFacts[cjsName] = sidebarFacts[libName];
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>World Map – Explore Every Country | TerraLenses</title>
  <meta name="description" content="Interactive world map. Click any country to explore facts, culture, geography and more." />
  <link rel="canonical" href="https://terralenses.com/map/" />
  <meta name="google-site-verification" content="jncrLZewF1YuN4wAuQFWpmCTFcOhhZjQCeyAdK03Bcc" />
  <link rel="alternate" hreflang="en" href="https://terralenses.com/map/" />
  <link rel="alternate" hreflang="fr" href="https://terralenses.com/fr/map/" />
  <link rel="alternate" hreflang="x-default" href="https://terralenses.com/map/" />
  <script>(function(){var c=localStorage.getItem('lang-choice');if(c)return;var isFr=(navigator.language||'').toLowerCase().startsWith('fr');if(isFr)window.location.replace('/fr'+window.location.pathname);})();</script>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />
  <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4020973443671350" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%; height: 100%;
      overflow: hidden;
      font-family: 'Inter', sans-serif;
      background: #0d1117;
    }

    /* ── Sidebar ─────────────────────────────── */
    #sidebar {
      position: fixed;
      top: 0; left: 0;
      width: 300px; height: 100%;
      z-index: 9500;
      background: #0d1117;
      border-right: 1px solid rgba(255,255,255,0.06);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* Welcome */
    #sb-welcome {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 28px 24px;
      transition: opacity 0.4s;
    }
    #sb-welcome.hidden { opacity: 0; pointer-events: none; }

    .sb-globe { font-size: 48px; margin-bottom: 4px; }
    .sb-welcome-title { font-size: 17px; font-weight: 600; color: #fff; letter-spacing: -0.02em; }
    .sb-welcome-sub   { font-size: 12px; color: rgba(255,255,255,0.28); margin-bottom: 12px; }

    .sb-rnk-section { width: 100%; display: flex; flex-direction: column; gap: 4px; }
    .sb-rnk-label { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.09em; color: rgba(255,255,255,0.2); margin-bottom: 2px; padding-left: 2px; }
    .sb-rnk-link {
      display: flex; align-items: center; gap: 8px;
      padding: 8px 12px; border-radius: 8px;
      font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.65);
      text-decoration: none;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      transition: background 0.15s, color 0.15s;
    }
    .sb-rnk-link:hover { background: rgba(255,255,255,0.09); color: #fff; }

    /* Country panel */
    #sb-country {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.4s;
      overflow-y: auto;
    }
    #sb-country.visible { opacity: 1; pointer-events: all; }

    /* Top accent bar (changes per continent) */
    #sb-accent {
      height: 3px;
      width: 100%;
      background: linear-gradient(90deg, #3b82f6, #8b5cf6);
      flex-shrink: 0;
    }

    /* Flag banner */
    #sb-banner {
      padding: 24px 24px 20px;
      display: flex;
      align-items: center;
      gap: 16px;
      flex-shrink: 0;
    }
    #sb-flag {
      font-size: 44px;
      line-height: 1;
      flex-shrink: 0;
    }
    .sb-name-block { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
    #sb-name {
      font-size: 22px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.03em;
      line-height: 1.1;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    #sb-region {
      font-size: 11px;
      color: rgba(255,255,255,0.3);
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .sb-divider {
      height: 1px;
      background: rgba(255,255,255,0.06);
      margin: 0 24px;
      flex-shrink: 0;
    }

    /* Primary stats */
    .sb-section-label {
      font-size: 10px;
      font-weight: 500;
      color: rgba(255,255,255,0.2);
      text-transform: uppercase;
      letter-spacing: 0.09em;
      padding: 16px 24px 10px;
    }

    .sb-primary-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      padding: 0 24px;
    }
    .sb-primary-stat {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 8px;
      padding: 12px 14px;
      display: flex;
      flex-direction: column;
      gap: 5px;
      margin: 2px;
    }
    .sb-primary-label {
      font-size: 10px;
      color: rgba(255,255,255,0.25);
      text-transform: uppercase;
      letter-spacing: 0.07em;
    }
    .sb-primary-val {
      font-size: 14px;
      font-weight: 500;
      color: rgba(255,255,255,0.88);
      line-height: 1.2;
    }

    /* Secondary stats */
    .sb-secondary-list {
      display: flex;
      flex-direction: column;
      gap: 0;
      padding: 0 24px;
    }
    .sb-secondary-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 9px 0;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .sb-secondary-row:last-child { border-bottom: none; }
    .sb-secondary-label {
      font-size: 11px;
      color: rgba(255,255,255,0.25);
    }
    .sb-secondary-val {
      font-size: 12px;
      font-weight: 500;
      color: rgba(255,255,255,0.65);
      text-align: right;
      max-width: 160px;
    }

    /* Did you know */
    .sb-fact {
      margin: 16px 24px 24px;
      padding: 14px 16px;
      background: rgba(59,130,246,0.07);
      border: 1px solid rgba(59,130,246,0.15);
      border-radius: 10px;
      flex-shrink: 0;
    }
    .sb-fact-label {
      font-size: 10px;
      font-weight: 500;
      color: rgba(59,130,246,0.7);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 7px;
      display: block;
    }
    .sb-fact-text {
      font-size: 12px;
      color: rgba(255,255,255,0.5);
      line-height: 1.65;
    }

    /* ── Map ─────────────────────────────────── */
    #map {
      position: fixed;
      top: 0; left: 300px;
      right: 0; bottom: 0;
    }
    .leaflet-container { background: #dde1e7 !important; }

    /* ── Mobile logo ─────────────────────────────── */
    #mobile-logo {
      display: none;
      position: fixed;
      top: 12px; left: 12px;
      z-index: 9600;
      font-size: 13px;
      font-weight: 600;
      color: rgba(255,255,255,0.7);
      letter-spacing: 0.02em;
      background: rgba(13,17,23,0.75);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      padding: 6px 12px;
      border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.08);
      pointer-events: none;
    }

    @media (max-width: 768px) {
      #sidebar     { display: none; }
      #map         { left: 0; }
      #mobile-logo { display: block; }
    }

    #lang-sw { position:fixed; top:14px; right:16px; z-index:9999; font-size:11px; font-weight:600; background:rgba(6,13,26,0.82); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,0.07); border-radius:8px; padding:5px 10px; display:flex; gap:5px; align-items:center; letter-spacing:0.04em; }
    #lang-sw a { color:rgba(255,255,255,0.3); text-decoration:none; transition:color 0.15s; }
    #lang-sw a.active { color:rgba(255,255,255,0.92); }
    #lang-sw a:hover { color:rgba(255,255,255,0.7); }
    #lang-sw span { color:rgba(255,255,255,0.12); }

    /* ── Sidebar ranking panel ──────────────────── */
    #sb-ranking { display:none; flex-direction:column; flex:1; overflow:hidden; }
    #sb-ranking.active { display:flex; }
  </style>
  <style is:global>
    .sr-list { flex:1; overflow-y:auto; padding:6px 0 20px; scrollbar-width:thin; scrollbar-color:rgba(255,255,255,0.12) transparent; }
    .sr-list::-webkit-scrollbar { width:4px; }
    .sr-list::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.12); border-radius:4px; }
    .sr-item:hover { background:rgba(255,255,255,0.05) !important; }
  </style>
</head>
<body>

  <div id="lang-sw"><a href="/map/" class="active" onclick="localStorage.setItem('lang-choice','en')">EN</a><span>/</span><a href="/fr/map/" onclick="localStorage.setItem('lang-choice','fr')">FR</a></div>
  <div id="mobile-logo">TerraLenses</div>

  <aside id="sidebar">

    <div id="sb-welcome">
      <div class="sb-globe">🌍</div>
      <div class="sb-welcome-title">TerraLenses</div>
      <div class="sb-welcome-sub">Hover a country to discover it</div>
      <div class="sb-rnk-section">
        <div class="sb-rnk-label">Rankings</div>
        <a class="sb-rnk-link" href="/rankings/largest-countries/">🌍 Largest Countries</a>
        <a class="sb-rnk-link" href="/rankings/most-populated/">👥 Most Populated</a>
        <a class="sb-rnk-link" href="/rankings/most-neighbors/">🤝 Most Borders</a>
        <a class="sb-rnk-link" href="/rankings/island-nations/">🏝 Island Nations</a>
        <a class="sb-rnk-link" href="/rankings/smallest-countries/">🔬 Smallest Countries</a>
      </div>
    </div>

    <div id="sb-country">
      <div id="sb-accent"></div>

      <div id="sb-banner">
        <span id="sb-flag"></span>
        <div class="sb-name-block">
          <div id="sb-name"></div>
          <div id="sb-region"></div>
        </div>
      </div>

      <div class="sb-divider"></div>

      <div class="sb-section-label">{t.keyFacts}</div>
      <div class="sb-primary-grid">
        <div class="sb-primary-stat">
          <span class="sb-primary-label">{t.capitalLabel}</span>
          <span class="sb-primary-val" id="sb-capital">—</span>
        </div>
        <div class="sb-primary-stat">
          <span class="sb-primary-label">{t.populationLabel}</span>
          <span class="sb-primary-val" id="sb-pop">—</span>
        </div>
        <div class="sb-primary-stat">
          <span class="sb-primary-label">{t.currencyLabel}</span>
          <span class="sb-primary-val" id="sb-currency">—</span>
        </div>
        <div class="sb-primary-stat">
          <span class="sb-primary-label">{t.languageLabel}</span>
          <span class="sb-primary-val" id="sb-lang">—</span>
        </div>
      </div>

      <div class="sb-section-label" style="padding-top:20px;">{t.moreInfo}</div>
      <div class="sb-secondary-list">
        <div class="sb-secondary-row">
          <span class="sb-secondary-label">{t.areaLabel}</span>
          <span class="sb-secondary-val" id="sb-area">—</span>
        </div>
        <div class="sb-secondary-row">
          <span class="sb-secondary-label">{t.religionLabel}</span>
          <span class="sb-secondary-val" id="sb-religion">—</span>
        </div>
      </div>

      <div class="sb-fact">
        <span class="sb-fact-label">{t.didYouKnow}</span>
        <span class="sb-fact-text" id="sb-fact">—</span>
      </div>
    </div>

    <div id="sb-ranking"></div>

  </aside>

  <div id="map"></div>

  <script set:html={`window.SIDEBAR_FACTS = ${JSON.stringify(sidebarFacts)};`}></script>
  <script set:html={`window._HIGHLIGHT=${JSON.stringify(highlightSlugs)};window._FROM=${JSON.stringify(fromParam)};window._HL_VALUES=${JSON.stringify(highlightValues)};`}></script>
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline src="/topojson.min.js"></script>
  <script is:inline src="/countries.js"></script>
  <script is:inline>
    const mapEl = document.getElementById('map');
    const mapW  = mapEl.clientWidth  || window.innerWidth;
    const mapH  = mapEl.clientHeight || window.innerHeight;
    // Portrait mobile: zoom by height so world fills the screen (not tiny with gray below)
    // Desktop/landscape: zoom by width (larger dim) — same as before
    const worldZoom    = Math.log2(Math.max(mapW, mapH) * 0.86 / 256);
    const minWorldZoom = Math.log2(mapW * 0.86 / 256); // allow zooming out to full world width

    const map = L.map('map', {
      center: [40, -25],
      zoom: worldZoom,
      minZoom: minWorldZoom,
      maxZoom: 18,
      maxBounds: [[-85.06, -180], [85.06, 180]],
      maxBoundsViscosity: 1.0,
      worldCopyJump: false,
      zoomControl: true,
      attributionControl: false
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png').addTo(map);

    // ── Sidebar ───────────────────────────────────────
    const ACCENT = {
      Europe:   'linear-gradient(90deg,#3b82f6,#6366f1)',
      Asia:     'linear-gradient(90deg,#f59e0b,#ef4444)',
      Africa:   'linear-gradient(90deg,#10b981,#f59e0b)',
      Americas: 'linear-gradient(90deg,#8b5cf6,#3b82f6)',
      Oceania:  'linear-gradient(90deg,#06b6d4,#10b981)',
    };

    function showCountry(info, data) {
      document.getElementById('sb-welcome').classList.add('hidden');
      document.getElementById('sb-country').classList.add('visible');
      document.getElementById('sb-accent').style.background = ACCENT[info.region] || ACCENT.Europe;
      document.getElementById('sb-flag').textContent     = info.flag     || '';
      document.getElementById('sb-name').textContent     = info.name     || '';
      document.getElementById('sb-region').textContent   = info.region   || '';
      document.getElementById('sb-capital').textContent  = data.capital  || '—';
      document.getElementById('sb-pop').textContent      = data.pop      || '—';
      document.getElementById('sb-currency').textContent = data.currency || '—';
      document.getElementById('sb-lang').textContent     = data.lang     || '—';
      document.getElementById('sb-area').textContent     = data.area     || '—';
      document.getElementById('sb-religion').textContent = data.religion || '—';
      document.getElementById('sb-fact').textContent     = (window.SIDEBAR_FACTS && window.SIDEBAR_FACTS[info.name]) || data.fact || '—';
    }

    function showWelcome() {
      document.getElementById('sb-welcome').classList.remove('hidden');
      document.getElementById('sb-country').classList.remove('visible');
    }

    // ── Country polygons ──────────────────────────────
    let geojsonLayer;
    const featureLayers = {};
    let hoveredId = null;

    const STYLE_DEFAULT   = { weight: 0.5, color: 'rgba(80,100,180,0.3)',  fillColor: 'rgba(0,0,0,0)', fillOpacity: 1 };
    const STYLE_HOVER     = { weight: 1.5, color: 'rgba(80,130,255,0.9)', fillColor: 'rgba(80,130,255,0.12)', fillOpacity: 1 };
    const _hlSlugs = new Set(window._HIGHLIGHT || []);

    // ── Per-rank color: hue goes from orange(30°) to blue(220°) ──────────────
    function _rankHue(i, total) {
      return Math.round(30 + (i / Math.max(total - 1, 1)) * 190);
    }
    function _rankStyle(i, total) {
      const h = _rankHue(i, total);
      return { weight: 2.5, color: `hsl(${h},85%,65%)`, fillColor: `hsl(${h},75%,55%)`, fillOpacity: 0.25 };
    }

    let _hlApplied = false;

    function buildRankingSidebar(hlArray, slugToInfo) {
      const panel = document.getElementById('sb-ranking');
      if (!panel) return;
      document.getElementById('sb-welcome').style.display = 'none';
      panel.classList.add('active');
      const FROM_LABELS = {
        'largest-countries': 'Top 30 Largest Countries',
        'smallest-countries': 'Smallest Countries',
        'most-populated':    'Most Populated',
        'most-neighbors':    'Most Land Neighbors',
        'island-nations':    'Island Nations',
      };
      const title = FROM_LABELS[window._FROM] || hlArray.length + ' countries';
      const linkUrl = window._FROM ? `/rankings/${window._FROM}/` : '/rankings/';
      const values = window._HL_VALUES || [];
      const total = hlArray.length;
      let items = '';
      for (let i = 0; i < total; i++) {
        const slug = hlArray[i];
        const info = slugToInfo[slug] || {};
        const h = _rankHue(i, total);
        const color = `hsl(${h},85%,65%)`;
        const cardBg = `hsla(${h},60%,40%,0.12)`;
        const cardHover = `hsla(${h},60%,40%,0.25)`;
        const value = values[i] || '';
        items +=
          `<a href="/country/${slug}/" style="display:flex;align-items:center;gap:9px;padding:9px 12px;text-decoration:none;margin:3px 10px;border-radius:8px;background:${cardBg};border:1px solid hsla(${h},60%,50%,0.15);" onmouseover="this.style.background='${cardHover}'" onmouseout="this.style.background='${cardBg}'">` +
            `<span style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.28);min-width:18px;text-align:right;flex-shrink:0;">${i+1}</span>` +
            `<div style="width:11px;height:11px;border-radius:3px;background:${color};flex-shrink:0;box-shadow:0 0 6px ${color};"></div>` +
            `<span style="font-size:20px;line-height:1;flex-shrink:0;">${info.flag||''}</span>` +
            `<div style="display:flex;flex-direction:column;gap:2px;min-width:0;flex:1;overflow:hidden;">` +
              `<span style="font-size:13px;font-weight:500;color:#e2e8f0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${info.name||slug}</span>` +
              (value ? `<span style="font-size:11px;color:rgba(255,255,255,0.42);font-variant-numeric:tabular-nums;">${value}</span>` : '') +
            `</div>` +
          `</a>`;
      }
      panel.innerHTML =
        `<div style="padding:14px 14px 10px;flex-shrink:0;border-bottom:1px solid rgba(255,255,255,0.06);">` +
          `<div style="font-size:13px;font-weight:600;color:#fff;margin-bottom:5px;">${title}</div>` +
          `<a href="${linkUrl}" style="font-size:11px;color:rgba(255,255,255,0.4);text-decoration:none;">← See full list</a>` +
        `</div>` +
        `<div style="flex:1;overflow-y:auto;padding:6px 0 16px;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,0.12) transparent;">${items}</div>`;
    }

    function applyHighlights() {
      if (_hlSlugs.size === 0) return;
      const hlArray = window._HIGHLIGHT || [];
      const total = hlArray.length;

      // Build slug → feature ID + info reverse maps
      const slugToId = {};
      const slugToInfo = {};
      for (const [id, info] of Object.entries(COUNTRY_ID_MAP)) {
        const pid = id.padStart(3, '0'); // world-atlas uses zero-padded 3-digit string IDs
        slugToId[info.slug] = pid;
        slugToInfo[info.slug] = info;
      }
      for (const [slug, info] of Object.entries(UK_NATIONS_INFO)) {
        slugToId[slug] = slug;
        slugToInfo[slug] = info;
      }
      // Slug aliases: countryData keys → COUNTRY_ID_MAP slugs
      const SLUG_ALIASES = {
        'united-states-of-america':          'united-states',
        'democratic-republic-of-the-congo':  'dr-congo',
        'republic-of-the-congo':             'republic-of-congo',
        'cabo-verde':                        'cape-verde',
        'cote-divoire':                      'ivory-coast',
      };
      for (const [alias, canonical] of Object.entries(SLUG_ALIASES)) {
        if (slugToId[canonical])   slugToId[alias]   = slugToId[canonical];
        if (slugToInfo[canonical]) slugToInfo[alias]  = slugToInfo[canonical];
      }

      // Apply per-rank colors to map layers
      for (let i = 0; i < hlArray.length; i++) {
        const slug = hlArray[i];
        const fid = slugToId[slug];
        if (!fid || !featureLayers[fid]) continue;
        const style = _rankStyle(i, total);
        featureLayers[fid].forEach(l => { l.setStyle(style); l.bringToFront(); });
      }

      // Build sidebar list (only on first call)
      if (!_hlApplied) {
        buildRankingSidebar(hlArray, slugToInfo);
        _hlApplied = true;
      }
    }

    // UK constituent nations info (used instead of COUNTRY_ID_MAP for UK features)
    const UK_NATIONS_INFO = {
      'england':          { name:'England',          slug:'england',          flag:'🏴󠁧󠁢󠁥󠁮󠁧󠁿', region:'Europe' },
      'scotland':         { name:'Scotland',          slug:'scotland',         flag:'🏴󠁧󠁢󠁳󠁣󠁴󠁿', region:'Europe' },
      'wales':            { name:'Wales',             slug:'wales',            flag:'🏴󠁧󠁢󠁷󠁬󠁳󠁿', region:'Europe' },
      'northern-ireland': { name:'Northern Ireland',  slug:'northern-ireland', flag:'🏴󠁧󠁢󠁮󠁩󠁲󠁿', region:'Europe' },
    };

    // Fix antimeridian: SPLIT polygons that cross ±180° into two valid polygons
    // (instead of extending past 180° which renders off-screen)
    function fixAntimeridian(feature) {
      const geom = feature.geometry;
      if (!geom) return;

      // Make ring coordinates continuous, then shift so midpoint is in [-180, 180]
      function makeCont(ring) {
        const r = [ring[0].slice()];
        for (let i = 1; i < ring.length; i++) {
          let x = ring[i][0];
          const px = r[i-1][0];
          while (x - px >  180) x -= 360;
          while (px - x >  180) x += 360;
          r.push([x, ring[i][1]]);
        }
        // Shift so the ring's midpoint lands in [-180, 180]
        // (fixes rings that start near -180° and drift to e.g. -332°)
        let minX = r[0][0], maxX = r[0][0];
        for (const p of r) { if (p[0] < minX) minX = p[0]; if (p[0] > maxX) maxX = p[0]; }
        const mid = (minX + maxX) / 2;
        let shift = 0;
        while (mid + shift >  180) shift -= 360;
        while (mid + shift < -180) shift += 360;
        if (shift !== 0) for (const p of r) p[0] += shift;
        return r;
      }

      function lerp(a, b, x) {
        const t = (x - a[0]) / (b[0] - a[0]);
        return [x, a[1] + t * (b[1] - a[1])];
      }

      // Split a ring that crosses 180° into two rings both within [-180, 180]
      function splitRing(ring) {
        const c = makeCont(ring);
        const n = c.length - 1; // exclude duplicate closing pt
        let minX = c[0][0], maxX = c[0][0];
        for (const p of c) { if (p[0] < minX) minX = p[0]; if (p[0] > maxX) maxX = p[0]; }
        const thresh = maxX > 180 ? 180 : minX < -180 ? -180 : null;
        if (thresh === null) return [c]; // no antimeridian crossing

        // Find the two crossing points
        const cross = [];
        for (let i = 0; i < n; i++) {
          const a = c[i], b = c[(i+1) % n];
          if ((a[0] - thresh) * (b[0] - thresh) < 0)
            cross.push({ i, pt: lerp(a, b, thresh), entering: b[0] > thresh });
        }
        if (cross.length !== 2) {
          // Fallback: just make continuous (may extend off-screen)
          return [c];
        }
        if (!cross[0].entering) cross.reverse();
        const [eC, xC] = cross; // entering / exiting the >180° zone

        // Ring A: main part, with a straight cut at the antimeridian
        const rA = [];
        for (let i = 0; i <= eC.i; i++) rA.push(c[i].slice());
        rA.push(eC.pt.slice());   // close to antimeridian going in
        rA.push(xC.pt.slice());   // re-open from antimeridian going out
        for (let i = xC.i + 1; i < n; i++) rA.push(c[i].slice());
        rA.push(rA[0].slice());   // close ring

        // Ring B: the stub past the antimeridian, shifted back into [-180, 180]
        const shift = thresh === 180 ? -360 : 360;
        const rB = [[eC.pt[0] + shift, eC.pt[1]]];
        for (let i = eC.i + 1; i <= xC.i; i++) rB.push([c[i][0] + shift, c[i][1]]);
        rB.push([xC.pt[0] + shift, xC.pt[1]]);
        rB.push(rB[0].slice());   // close ring

        return [rA, rB];
      }

      const polys = geom.type === 'MultiPolygon' ? geom.coordinates : [geom.coordinates];
      const newPolys = [];
      for (const poly of polys) {
        const rings = splitRing(poly[0]);
        for (const r of rings) newPolys.push([r]);
      }
      feature.geometry = { type: 'MultiPolygon', coordinates: newPolys };

    }

    // Point-in-polygon (ray casting) — skips antimeridian edges (jumps > 180°)
    function ptInRing(lng, lat, ring) {
      let inside = false;
      for (let i = 0, j = ring.length - 1; i < ring.length; j = i++) {
        const xi = ring[i][0], yi = ring[i][1], xj = ring[j][0], yj = ring[j][1];
        if (Math.abs(xi - xj) > 180) continue; // skip antimeridian-crossing edges
        if (((yi > lat) !== (yj > lat)) && (lng < (xj - xi) * (lat - yi) / (yj - yi) + xi))
          inside = !inside;
      }
      return inside;
    }

    // Pre-computed bboxes for fast rejection
    const featureBboxes = {};

    function ptInFeature(lng, lat, feature) {
      const bb = featureBboxes[feature.id];
      if (!bb) return false;
      // Test lng and lng+360 to handle antimeridian-normalized polygons
      for (const testLng of [lng, lng + 360]) {
        if (testLng < bb[0] || testLng > bb[2] || lat < bb[1] || lat > bb[3]) continue;
        const g = feature.geometry;
        const polys = g.type === 'MultiPolygon' ? g.coordinates : [g.coordinates];
        for (const poly of polys) {
          if (ptInRing(testLng, lat, poly[0])) return true;
        }
      }
      return false;
    }

    fetch('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-10m.json')
      .then(r => r.json())
      .then(world => {
        const geojson = topojson.feature(world, world.objects.countries);

        // Remove UK (826) from world-atlas — replaced by the constituent nations layer below
        geojson.features = geojson.features.filter(f => String(f.id) !== '826');

        // Fix antimeridian first so Russia's ring is split into proper eastern/western halves
        // instead of spanning x=[-180,180] which makes its bbox cover the entire globe.
        geojson.features.forEach(fixAntimeridian);

        // Drop sub-polygons that are eastern-hemisphere countries with fragments
        // at very negative longitudes (e.g. Russia's tiny bits near Alaska).
        geojson.features.forEach(f => {
          if (!f.geometry || f.geometry.type !== 'MultiPolygon') return;
          const polys = f.geometry.coordinates;
          if (polys.length < 2) return;
          const ctr = p => { let s=0; for (const [x] of p[0]) s+=x; return s/p[0].length; };
          const centers = polys.map(ctr);
          const mainIdx = polys.map((p,i)=>[i,p[0].length]).sort((a,b)=>b[1]-a[1])[0][0];
          if (centers[mainIdx] > 0)
            f.geometry.coordinates = polys.filter((_,i) => centers[i] > -50);
        });

        // Build hitRings and featureBboxes from the now-fixed coordinates
        const hitRings = new Map();
        for (const f of geojson.features) {
          const g = f.geometry;
          if (!g) continue;
          const polys = g.type === 'MultiPolygon' ? g.coordinates : [g.coordinates];
          const newRings = polys.map(poly => poly[0].map(pt => [pt[0], pt[1]]));
          if (hitRings.has(f.id)) hitRings.get(f.id).push(...newRings);
          else hitRings.set(f.id, newRings);
          let [x0,y0,x1,y1] = featureBboxes[f.id] || [Infinity,Infinity,-Infinity,-Infinity];
          for (const poly of polys)
            for (const [x,y] of poly[0]) {
              if(x<x0)x0=x; if(x>x1)x1=x; if(y<y0)y0=y; if(y>y1)y1=y;
            }
          featureBboxes[f.id] = [x0,y0,x1,y1];
        }

        geojsonLayer = L.geoJSON(geojson, {
          style: STYLE_DEFAULT,
          onEachFeature: (feature, layer) => {
            // A feature ID may have multiple layers (e.g. Russia split at antimeridian)
            if (!featureLayers[feature.id]) featureLayers[feature.id] = [];
            featureLayers[feature.id].push(layer);
          }
        }).addTo(map);

        // ── Custom overlay for countries absent from world-atlas ──────────
        // Kosovo (383) is not in world-atlas; add its approximate polygon.
        const CUSTOM_FEATURES = [
          { id: '383', coordinates: [[[20.03,42.93],[20.28,42.98],[20.40,43.01],[20.50,43.08],[20.78,43.24],[20.82,43.27],[21.15,43.10],[21.55,43.03],[21.79,42.90],[21.79,42.30],[21.56,42.33],[21.30,42.15],[21.02,42.07],[20.63,42.00],[20.55,42.21],[20.34,42.43],[20.08,42.66],[20.03,42.93]]] },
        ];
        for (const cf of CUSTOM_FEATURES) {
          const ring = cf.coordinates[0];
          let x0=Infinity,x1=-Infinity,y0=Infinity,y1=-Infinity;
          for (const [x,y] of ring) { if(x<x0)x0=x;if(x>x1)x1=x;if(y<y0)y0=y;if(y>y1)y1=y; }
          featureBboxes[cf.id] = [x0,y0,x1,y1];
          hitRings.set(cf.id, [ring.map(pt=>[pt[0],pt[1]])]);
          const layer = L.geoJSON({ type:'Feature', id:cf.id, geometry:{ type:'Polygon', coordinates:cf.coordinates } }, { style: STYLE_DEFAULT });
          if (!featureLayers[cf.id]) featureLayers[cf.id] = [];
          layer.eachLayer(l => featureLayers[cf.id].push(l));
          layer.addTo(map);
          // Inject into geojson.features so the mousemove hit-test loop picks it up
          geojson.features.push({ id: cf.id, geometry: { type: 'Polygon', coordinates: cf.coordinates } });
        }
        // Apply highlights for world-atlas + custom countries
        applyHighlights();

        // ── UK constituent nations layer ─────────────────────────────────
        fetch('/uk-nations.geojson')
          .then(r => r.json())
          .then(ukData => {
            for (const f of ukData.features) {
              const id = f.properties.slug;
              f.id = id;

              // Register for hit-testing
              geojson.features.push(f);

              const geom = f.geometry;
              const polys = geom.type === 'MultiPolygon' ? geom.coordinates : [geom.coordinates];
              const rings = [];
              let x0=Infinity, x1=-Infinity, y0=Infinity, y1=-Infinity;
              for (const poly of polys) {
                rings.push(poly[0].map(pt => [pt[0], pt[1]]));
                for (const [x, y] of poly[0]) {
                  if(x<x0)x0=x; if(x>x1)x1=x; if(y<y0)y0=y; if(y>y1)y1=y;
                }
              }
              hitRings.set(id, rings);
              featureBboxes[id] = [x0, y0, x1, y1];

              // Add Leaflet layer (rendered on top of world layer)
              const layer = L.geoJSON(f, { style: STYLE_DEFAULT });
              featureLayers[id] = [];
              layer.eachLayer(l => featureLayers[id].push(l));
              layer.addTo(map);
            }
            // Re-apply highlights for UK nations (loaded asynchronously)
            applyHighlights();
          });

        // ── Custom hover via mousemove ────────────────────────────────────
        map.on('mousemove', (e) => {
          const { lat, lng } = e.latlng;
          let foundId = null;
          let foundArea = Infinity;
          const checkedIds = new Set();
          for (const f of geojson.features) {
            if (checkedIds.has(f.id)) continue;
            checkedIds.add(f.id);
            const bb = featureBboxes[f.id];
            if (!bb || lng < bb[0]-1 || lng > bb[2]+1 || lat < bb[1]-1 || lat > bb[3]+1) continue;
            const rings = hitRings.get(f.id);
            if (!rings) continue;
            for (const ring of rings) {
              if (ptInRing(lng, lat, ring)) {
                const area = (bb[2] - bb[0]) * (bb[3] - bb[1]);
                if (area < foundArea) { foundId = f.id; foundArea = area; }
                break;
              }
            }
          }

          if (_hlSlugs.size > 0) {
            // Ranking mode: only update cursor, no hover styles or sidebar changes
            hoveredId = foundId;
            mapEl.style.cursor = foundId ? 'pointer' : '';
            return;
          }

          if (foundId === hoveredId) return;
          if (hoveredId && featureLayers[hoveredId]) featureLayers[hoveredId].forEach(l => l.setStyle(STYLE_DEFAULT));
          hoveredId = foundId;
          if (foundId) {
            const info = COUNTRY_ID_MAP[+foundId] || UK_NATIONS_INFO[foundId];
            if (info && featureLayers[foundId]) {
              featureLayers[foundId].forEach(l => { l.setStyle(STYLE_HOVER); l.bringToFront(); });
              showCountry(info, COUNTRY_DATA[info.name] || {});
              mapEl.style.cursor = 'pointer';
            }
          } else {
            showWelcome();
            mapEl.style.cursor = '';
          }
        });

        map.on('mouseout', () => {
          if (_hlSlugs.size === 0) {
            if (hoveredId && featureLayers[hoveredId]) featureLayers[hoveredId].forEach(l => l.setStyle(STYLE_DEFAULT));
            showWelcome();
          }
          hoveredId = null; mapEl.style.cursor = '';
        });

        map.on('click', (e) => {
          if (window.innerWidth <= 768) {
            // Mobile: no hover state — hit-test the tap position directly
            const { lat, lng } = e.latlng;
            let foundId = null, foundArea = Infinity;
            const checkedIds = new Set();
            for (const f of geojson.features) {
              if (checkedIds.has(f.id)) continue;
              checkedIds.add(f.id);
              const bb = featureBboxes[f.id];
              if (!bb || lng < bb[0]-1 || lng > bb[2]+1 || lat < bb[1]-1 || lat > bb[3]+1) continue;
              const rings = hitRings.get(f.id);
              if (!rings) continue;
              for (const ring of rings) {
                if (ptInRing(lng, lat, ring)) {
                  const area = (bb[2] - bb[0]) * (bb[3] - bb[1]);
                  if (area < foundArea) { foundId = f.id; foundArea = area; }
                  break;
                }
              }
            }
            if (foundId) {
              const info = COUNTRY_ID_MAP[+foundId] || UK_NATIONS_INFO[foundId];
              if (info && info.slug) window.location.href = '/country/' + info.slug;
            }
          } else {
            // Desktop: use hover state set by mousemove
            if (!hoveredId) return;
            const info = COUNTRY_ID_MAP[+hoveredId] || UK_NATIONS_INFO[hoveredId];
            if (info) window.location.href = '/country/' + info.slug;
          }
        });
      });
  </script>

</body>
</html>
