---
import Base from '../layouts/Base.astro';
---
<Base
  title="Contact — TerraLenses"
  description="Contact TerraLenses. Questions, feedback or partnership inquiries welcome."
  lang="en"
  hreflangEn="https://terralenses.com/contact/"
  hreflangFr="https://terralenses.com/fr/contact/"
>
  <main id="main-content" style="max-width:760px;margin:0 auto;padding:64px 24px 80px;">
    <h1 style="font-family:'Playfair Display',serif;font-size:36px;font-weight:700;color:#fff;margin-bottom:8px;">Contact</h1>
    <p style="color:rgba(255,255,255,0.35);font-size:13px;margin-bottom:48px;">We'd love to hear from you.</p>

    <section style="margin-bottom:36px;">
      <h2 style="font-size:18px;font-weight:600;color:rgba(147,197,253,0.9);margin-bottom:12px;">Get in touch</h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.55);line-height:1.75;">
        For any question, feedback, or partnership inquiry, feel free to reach out by email:
      </p>
      <p style="margin-top:16px;">
        <a href="mailto:mic.thomas1334@gmail.com" style="color:#60a5fa;font-size:16px;font-weight:500;">mic.thomas1334@gmail.com</a>
      </p>
    </section>

    <section style="margin-bottom:36px;">
      <h2 style="font-size:18px;font-weight:600;color:rgba(147,197,253,0.9);margin-bottom:12px;">About TerraLenses</h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.55);line-height:1.75;">
        TerraLenses is an interactive world atlas covering 195 countries — cultures, landscapes, statistics and comparisons. Our goal is to make geography accessible and engaging for everyone.
      </p>
    </section>

    <p style="margin-top:48px;">
      <a href="/" style="color:#60a5fa;font-size:14px;text-decoration:none;">← Back to TerraLenses</a>
    </p>
  </main>
</Base>
