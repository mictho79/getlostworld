---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import { COUNTRY_DATA as DATA_EN, COUNTRY_VIBES as VIBES_EN, COUNTRY_PEAKS, COUNTRY_DISHES, COUNTRY_CITIES, COUNTRY_INSIGHTS as INSIGHTS_EN, slugify } from '../../lib/countryData.js';
import { COUNTRY_CCN3 } from '../../lib/countryCodes.js';
import { TRAVEL_ADVISORY } from '../../lib/travelScores.js';
import { geojsonToSvgPath } from '../../lib/geojsonSvg.js';
import { getT, translateRegion } from '../../i18n/translations';
import { detectLang } from '../../i18n/detect';

// ─── Slug aliases ──────────────────────────────────────────────────────────────
const SLUG_ALIASES: Record<string,string> = {
  'united-states':   '/country/united-states-of-america/',
  'usa':             '/country/united-states-of-america/',
  'uk':              '/country/england/',
  'united-kingdom':  '/country/england/',
  'czechia':         '/country/czech-republic/',
  'dr-congo':        '/country/democratic-republic-of-the-congo/',
  'ivory-coast':     '/country/cote-divoire/',
  'cape-verde':      '/country/cabo-verde/',
};

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/');
if (SLUG_ALIASES[slug as string]) return Astro.redirect(SLUG_ALIASES[slug as string], 301);

// ─── Language detection ────────────────────────────────────────────────────────
const lang = detectLang(Astro.request.headers.get('accept-language') ?? 'en');
const t = getT(lang);
const tr = (r: string) => translateRegion(r, lang);

let countryVibes:    typeof VIBES_EN    = VIBES_EN;
let countryDataSrc:  typeof DATA_EN     = DATA_EN;
let countryInsights: typeof INSIGHTS_EN = INSIGHTS_EN;

if (lang === 'fr') {
  const fr = await import('../../lib/countryData.fr.js');
  // Merge EN as base so nations missing from the FR translation (e.g. England, Scotland,
  // Wales, Northern Ireland) fall back to English rather than returning undefined.
  countryVibes    = { ...(VIBES_EN    as any), ...(fr.COUNTRY_VIBES    as any) };
  countryDataSrc  = { ...(DATA_EN     as any), ...(fr.COUNTRY_DATA     as any) };
  countryInsights = { ...(INSIGHTS_EN as any), ...(fr.COUNTRY_INSIGHTS as any) };
}

// ─── Helpers ───────────────────────────────────────────────────────────────────
function formatPop(n: number): string {
  if (!n) return '—';
  if (n >= 1e9) return (n / 1e9).toFixed(1) + 'B';
  if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M';
  if (n >= 1e3) return (n / 1e3).toFixed(0) + 'K';
  return String(n);
}
function formatCurrency(c: any): string {
  if (!c) return '—';
  const vals = Object.values(c) as any[];
  if (!vals.length) return '—';
  return vals.map((v: any) => `${v.name}${v.symbol ? ' (' + v.symbol + ')' : ''}`).join(', ');
}

// ─── REST name mapping ─────────────────────────────────────────────────────────
const LOCAL_TO_REST: Record<string,string> = {
  'Czech Republic':                   'Czechia',
  'United States of America':         'United States',
  'Democratic Republic of the Congo': 'DR Congo',
  'Cabo Verde':                       'Cape Verde',
  "Côte d'Ivoire":                    'Ivory Coast',
};
const REST_TO_LOCAL: Record<string,string> = {
  'Czechia':       'Czech Republic',
  'United States': 'United States of America',
  'DR Congo':      'Democratic Republic of the Congo',
  'Cape Verde':    'Cabo Verde',
  'Ivory Coast':   "Côte d'Ivoire",
};

// ─── Find local name by slug — fall back to EN keys for untranslated nations ──
const localName =
  Object.keys(countryDataSrc as any).find(k => slugify(k) === slug) ||
  (lang !== 'en' ? Object.keys(DATA_EN as any).find(k => slugify(k) === slug) : undefined);
if (!localName) return Astro.redirect('/');
const localData = (countryDataSrc as any)[localName] || (DATA_EN as any)[localName] || {};
const restName  = LOCAL_TO_REST[localName] || localName;

// ─── Fetch REST data for this country ─────────────────────────────────────────
const RF = 'name,capital,population,languages,flags,area,cca2,cca3,ccn3,latlng,region,subregion,currencies,timezones,idd,borders,car';
let rc: any = null;
try {
  const res  = await fetch(`https://restcountries.com/v3.1/name/${encodeURIComponent(restName)}?fullText=true&fields=${RF}`);
  const data = await res.json();
  rc = Array.isArray(data) ? data[0] : null;
} catch { /* fall back to local data */ }

// ─── Build SVG shape ───────────────────────────────────────────────────────────
let svgShape   = '';
let svgViewBox = '0 0 400 300';
try {
  const topojson = await import('topojson-client');
  const { default: worldTopo } = await import('world-atlas/countries-10m.json');
  const geojson  = topojson.feature(worldTopo, worldTopo.objects.countries);
  const ccn3     = rc?.ccn3 || (COUNTRY_CCN3 as any)[localName] || '';
  if (ccn3) {
    const numId = String(+ccn3).padStart(3, '0');
    const feat  = (geojson as any).features.find((f: any) => String(f.id) === numId);
    if (feat) {
      const result = geojsonToSvgPath(feat);
      if (result) { svgShape = result.path; svgViewBox = result.viewBox; }
    }
  }
} catch { /* no shape */ }

// ─── Resolve border countries ──────────────────────────────────────────────────
const borderCodes: string[] = rc?.borders || [];
let borderCountries: { name: string; slug: string }[] = [];
if (borderCodes.length > 0) {
  try {
    const bRes  = await fetch(`https://restcountries.com/v3.1/alpha?codes=${borderCodes.join(',')}&fields=name,cca3`);
    const bData = await bRes.json();
    if (Array.isArray(bData)) {
      borderCountries = bData
        .map((b: any) => { const n = REST_TO_LOCAL[b.name?.common] || b.name?.common || ''; return { name: n, slug: slugify(n) }; })
        .filter((b: any) => b.name);
    }
  } catch { /* no borders */ }
}

// ─── Build country object ──────────────────────────────────────────────────────
const country = {
  name:            localName,
  officialName:    rc?.name?.official || localName,
  slug:            slug as string,
  flag:            localData.flag || rc?.flags?.emoji || '🌍',
  capital:         localData.capital || rc?.capital?.[0] || '—',
  population:      localData.population || formatPop(rc?.population),
  language:        localData.language || Object.values(rc?.languages || {}).join(', ') || '—',
  sport:           localData.sport || '—',
  fact:            localData.fact  || '',
  vibe:            (countryVibes as any)[localName] || 'Fascinating · Historic · Unique',
  area:            rc?.area ? Math.round(rc.area).toLocaleString('en-US') : '—',
  region:          rc?.region    || '',
  subregion:       rc?.subregion || '',
  latlng:          (rc?.latlng   || [0, 0]) as [number, number],
  currency:        formatCurrency(rc?.currencies),
  timezone:        rc?.timezones?.[0] || '—',
  callingCode:     rc?.idd?.root ? rc.idd.root + (rc.idd.suffixes?.length === 1 ? rc.idd.suffixes[0] : '') : '—',
  drivingSide:     rc?.car?.side === 'left' ? 'Left' : rc?.car?.side === 'right' ? 'Right' : '—',
  borderCountries,
  dish:            (COUNTRY_DISHES  as any)[localName] || null,
  peak:            (COUNTRY_PEAKS   as any)[localName] || null,
  cities:          (COUNTRY_CITIES  as any)[localName] || [],
  svgShape,
  svgViewBox,
};

const ci = (countryInsights as Record<string, Record<string, string>>)[country.name] || {};
const advisory = (TRAVEL_ADVISORY as Record<string,string>)[country.name] ?? null;
const isDNT     = advisory === 'do-not-travel';
const isRecon   = advisory === 'reconsider';

const REGION_ACCENT: Record<string, string> = {
  'Europe':   '#5b8fff',
  'Asia':     '#ff7043',
  'Africa':   '#ffb74d',
  'Americas': '#69d89a',
  'Oceania':  '#26c6da',
  'Antarctic':'#b0c4de',
};
const accent = REGION_ACCENT[country.region] || '#aaaaaa';

const countriesList = [...new Set([
  ...Object.keys(countryDataSrc as Record<string, unknown>),
  ...Object.keys(countryVibes as Record<string, unknown>),
])].sort().map(name => ({ name, slug: slugify(name) }));

const siteBase = Astro.site?.href ?? 'https://terralenses.com/';
const pageUrl  = new URL(`country/${country.slug}/`, siteBase).href;

const title       = `${country.name} – Facts, Capital & Geography | TerraLenses`;
const description = [
  `${country.name} is a country in ${country.subregion || country.region}.`,
  country.capital    !== '—' ? `Capital: ${country.capital}.`       : '',
  country.population !== '—' ? `Population: ${country.population}.` : '',
  country.language   !== '—' ? `Language: ${country.language}.`     : '',
  country.fact ? country.fact.slice(0, 110) + '…' : country.vibe,
].filter(Boolean).join(' ');

// ── SEO insight paragraphs ──────────────────────────────────────────
const insights: {icon:string; title:string; text:string}[] = [];

if (country.capital !== '—') {
  const otherCities = country.cities.slice(0, 3).map((c: {name:string}) => c.name);
  const cityLine = otherCities.length
    ? `${t.capBeyond}${otherCities.join(', ')}${t.capCitiesHub}`
    : '';
  insights.push({ icon: '🏛', title: t.insightCapital,
    text: `${country.capital}${t.capServes}${country.name}${country.subregion ? `${t.capPositionedIn}${tr(country.subregion)}` : ''}${t.capSeat}${cityLine}${ci.capital ? ' ' + ci.capital : ''}` });
}

if (country.population !== '—') {
  const langs = country.language !== '—' ? country.language : null;
  const plural = langs?.includes(',');
  const langNote = langs
    ? ` ${plural ? t.popLangsAre : t.popLangIs}${langs}${plural ? t.popLangReflect : t.popLangReflects}`
    : '';
  const callNote = country.callingCode !== '—' ? `${t.popInternationally}${country.name}${t.popDialCode}${country.callingCode}${t.popDialCodeEnd}` : '';
  insights.push({ icon: '👥', title: t.insightPeople,
    text: `${t.aboutPopApprox.trimStart()}${country.population}, ${country.name}${t.popVibrant}${langNote}${callNote}${ci.people ? ' ' + ci.people : ''}` });
}

if (country.area !== '—') {
  const loc = country.subregion
    ? `${t.geoInThe}${tr(country.subregion)}${t.geoSubregionOf}${tr(country.region)}`
    : country.region ? `${t.geoIn}${tr(country.region)}` : '';
  const coords = country.latlng[0] !== 0 || country.latlng[1] !== 0
    ? `${t.geoGeoCentred}${Math.abs(country.latlng[0]).toFixed(1)}°${country.latlng[0] >= 0 ? 'N' : 'S'}, ${Math.abs(country.latlng[1]).toFixed(1)}°${country.latlng[1] >= 0 ? 'E' : 'W'},`
    : '';
  const drive = country.drivingSide !== '—'
    ? `${country.drivingSide === 'Left' ? t.geoLeftHandRule : t.geoRightHandRule}${tr(country.region) || 'regional'}${t.geoConvention}`
    : '';
  insights.push({ icon: '🗺', title: t.insightGeography,
    text: `${country.name}${t.geoSpans}${country.area} km²${loc ? `, ${loc}` : ''}.${coords}${t.geoDiverseLandscapes}${drive}` });
}

if (country.currency !== '—') {
  const tzNote = country.timezone !== '—'
    ? `${t.econBusiness}${country.timezone}${t.econAligning}`
    : '';
  insights.push({ icon: '💱', title: t.insightEconomy,
    text: `${t.econCurrencyIs}${country.currency}${t.econUsedFor}${t.econShapedPre}${country.name}${t.econShapedPost}${tzNote}` });
}

if (country.dish) {
  insights.push({ icon: '🍽', title: t.insightFood,
    text: `${t.foodEmblem}${country.name}${t.foodIs}${country.dish}. ${ci.food ? ci.food : `${t.foodCulture}${country.name}${t.foodTied}`}` });
}

if (country.sport !== '—') {
  insights.push({ icon: '🏅', title: t.insightSport,
    text: `${country.sport}${t.sportHolds}${country.name}${t.sportNatId}${ci.sport ? ci.sport : `${t.sportIn}${country.name}${t.sportBeyond}`}` });
}

if (country.peak) {
  const elev = country.peak.elevation.toLocaleString('en-US');
  insights.push({ icon: '⛰', title: t.insightNature,
    text: `${t.natureHighest}${country.name}${t.natureIs}${country.peak.name}${t.natureRising}${elev}${t.natureMetres}${ci.nature ? ci.nature : t.natureEmbodies}` });
}

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "TerraLenses", "item": siteBase },
        { "@type": "ListItem", "position": 2, "name": country.name,     "item": pageUrl  }
      ]
    },
    {
      "@type": "Place",
      "name": country.name,
      ...(country.officialName !== country.name ? { "alternateName": country.officialName } : {}),
      "description": description,
      "url": pageUrl,
      ...(country.latlng[0] !== 0 || country.latlng[1] !== 0 ? {
        "geo": { "@type": "GeoCoordinates", "latitude": country.latlng[0], "longitude": country.latlng[1] }
      } : {}),
      ...(country.region ? { "containedInPlace": { "@type": "Continent", "name": country.region } } : {})
    }
  ]
});
---

<Base title={title} description={description} countryName={country.name}>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <div class="cp-page" style={`--accent:${accent};`}>

  <!-- ── Decorative background (always visible) ── -->
  <div class="cp-bg-deco" aria-hidden="true">
    <div class="cp-bg-ring cp-bg-ring-1"></div>
    <div class="cp-bg-ring cp-bg-ring-2"></div>
    <div class="cp-bg-ring cp-bg-ring-3"></div>
    {country.svgShape && (
      <svg class="cp-shape-svg" viewBox={country.svgViewBox} xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
        <path d={country.svgShape} />
      </svg>
    )}
  </div>

  <div class="cp-wrap">

    <!-- Back -->
    <a href="/map" class="cp-back">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8l4-4"/></svg>
      {t.backToMap}
    </a>

    <!-- Hero -->
    <header class="cp-hero">
      {country.svgShape ? (
        <div class="cp-hero-shape" aria-hidden="true">
          <svg viewBox={country.svgViewBox} xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
            <path d={country.svgShape} />
          </svg>
        </div>
      ) : (
        <span class="cp-flag" role="img" aria-label={`Flag of ${country.name}`}>{country.flag}</span>
      )}
      <h1 class="cp-title">{country.name}</h1>
      {country.officialName !== country.name && <p class="cp-official">{country.officialName}</p>}
      <p class="cp-region">{tr(country.subregion || country.region)}</p>
      <p class="cp-vibe">{country.vibe}</p>
    </header>

    <hr class="cp-divider" />

    <!-- Advisory banner -->
    {isRecon && (
      <div class="cp-advisory cp-advisory--reconsider" role="alert">
        <span>⚠️</span>
        <span>{t.advisoryReconsiderPre}<strong>{country.name}</strong>{t.advisoryReconsiderPost}</span>
      </div>
    )}
    {isDNT && (
      <div class="cp-advisory cp-advisory--dnt" role="alert">
        <span>⛔</span>
        <span>{t.advisoryDntPre}<strong>{country.name}</strong>{t.advisoryDntPost}</span>
      </div>
    )}

    <!-- Key facts -->
    <section class="cp-section" aria-label="Key facts">
      <h2 class="cp-section-label">{t.keyFacts}</h2>
      <div class="cp-stats-grid">
        {country.capital    !== '—' && <div class="cp-stat"><span class="cp-stat-label">{t.capitalLabel}</span><span class="cp-stat-val">{country.capital}</span></div>}
        {country.population !== '—' && <div class="cp-stat"><span class="cp-stat-label">{t.populationLabel}</span><span class="cp-stat-val">{country.population}</span></div>}
        {country.language   !== '—' && <div class="cp-stat"><span class="cp-stat-label">{country.language.includes(',') ? t.languagesLabel : t.languageLabel}</span><span class="cp-stat-val">{country.language}</span></div>}
        {country.area       !== '—' && <div class="cp-stat"><span class="cp-stat-label">{t.areaLabel}</span><span class="cp-stat-val">{country.area} km²</span></div>}
        {country.currency   !== '—' && <div class="cp-stat"><span class="cp-stat-label">{t.currencyLabel}</span><span class="cp-stat-val">{country.currency}</span></div>}
        {country.timezone   !== '—' && <div class="cp-stat"><span class="cp-stat-label">{t.timezoneLabel}</span><span class="cp-stat-val">{country.timezone}</span></div>}
        {country.callingCode !== '—' && <div class="cp-stat"><span class="cp-stat-label">{t.callingCodeLabel}</span><span class="cp-stat-val">{country.callingCode}</span></div>}
        {country.drivingSide !== '—' && <div class="cp-stat"><span class="cp-stat-label">{t.drivesOnLabel}</span><span class="cp-stat-val">{country.drivingSide === 'Left' ? t.driveLeft : t.driveRight}</span></div>}
        {country.sport       !== '—' && <div class="cp-stat"><span class="cp-stat-label">{t.nationalSportLabel}</span><span class="cp-stat-val">{country.sport}</span></div>}
        {country.dish                && <div class="cp-stat"><span class="cp-stat-label">{t.nationalDishLabel}</span><span class="cp-stat-val">{country.dish}</span></div>}
      </div>
    </section>

    <!-- Compare button -->
    <div class="cp-compare-wrap">
      <button class="cp-compare-btn" id="cp-compare-open" data-slug={country.slug} data-name={country.name}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="7" height="18"/><rect x="14" y="3" width="7" height="18"/>
        </svg>
        {t.compareWithAnother}
      </button>
    </div>

    <!-- About -->
    <section class="cp-section">
      <h2 class="cp-section-label">{t.aboutSection} {country.name}</h2>
      <p class="cp-about">
        <strong>{country.name}</strong>{country.officialName !== country.name ? ` (${t.aboutOfficially} ${country.officialName})` : ''}{country.subregion ? `${t.aboutIsCountryLocatedIn}${tr(country.subregion)}.` : country.region ? `${t.aboutIsCountryIn}${tr(country.region)}.` : t.aboutIsCountry}
        {country.capital !== '—' && <>{t.aboutCapitalIs}<strong>{country.capital}</strong>{`${country.cities.length > 0 ? `${t.aboutWithOtherCities}${country.cities.slice(0, 2).map((c: {name:string}) => c.name).join(` ${t.andConj} `)}` : ''}.`}</>}
        {country.population !== '—' && <>{t.aboutPopApprox}<strong>{country.population}</strong>{country.language !== '—' ? <>{country.language.includes(',') ? t.aboutMainLangsAre : t.aboutMainLangIs}<strong>{country.language}</strong>{'.'}</> : '.'}</>}
        {country.area !== '—' && <>{t.aboutCoversArea}<strong>{country.area} km²</strong>{'.'}</>}
        {country.currency !== '—' && <>{t.aboutOfficialCurrency}<strong>{country.currency}</strong>{'.'}</>}
        {country.drivingSide !== '—' && (country.drivingSide === 'Left' ? t.aboutDrivesLeft : t.aboutDrivesRight)}
      </p>
    </section>

    <!-- Did you know -->
    {country.fact && (
      <section class="cp-section">
        <h2 class="cp-section-label">{t.didYouKnow}</h2>
        <blockquote class="cp-fact">{country.fact}</blockquote>
      </section>
    )}

    <!-- SEO Insight paragraphs -->
    {insights.length > 0 && (
      <section class="cp-section">
        <h2 class="cp-section-label">{t.exploreSection} {country.name}</h2>
        <div class="cp-insights">
          {insights.map(ins => (
            <div class="cp-insight">
              <div class="cp-insight-head">
                <span class="cp-insight-icon">{ins.icon}</span>
                <h3 class="cp-insight-title">{ins.title}</h3>
              </div>
              <p class="cp-insight-text">{ins.text}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Cities -->
    {country.cities.length > 0 && (
      <section class="cp-section">
        <h2 class="cp-section-label">{t.majorCities}</h2>
        <div class="cp-cities">
          <div class="cp-city cp-city--capital">
            <span class="cp-city-dot cp-city-dot--capital"></span>
            <span class="cp-city-name">{country.capital}</span>
            <span class="cp-city-tag">{t.capitalTag}</span>
          </div>
          {country.cities.map(city => (
            <div class="cp-city">
              <span class="cp-city-dot"></span>
              <span class="cp-city-name">{city.name}</span>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Neighbouring countries -->
    {country.borderCountries.length > 0 && (
      <nav class="cp-section" aria-label="Neighbouring countries">
        <h2 class="cp-section-label">{t.neighbouringCountries}</h2>
        <div class="cp-neighbours">
          {country.borderCountries.map(b => (
            <a href={`/country/${b.slug}/`} class="cp-neighbour">{b.name}</a>
          ))}
        </div>
      </nav>
    )}

    <!-- CTA map -->
    {!isDNT && (
      <div class="cp-map-cta">
        <a href="/map" class="cp-map-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          {isRecon ? `${t.viewOnMapPre}${country.name}${t.viewOnMapPost}` : t.exploreOnMap}
        </a>
      </div>
    )}

  </div>
  <!-- Countries data for modal autocomplete -->
  <script type="application/json" id="cp-countries-data" set:html={JSON.stringify(countriesList)} />

  <!-- Compare modal -->
  <div class="cp-modal-overlay" id="cp-modal" hidden aria-modal="true" role="dialog" aria-label="Compare countries">
    <div class="cp-modal-box">
      <div class="cp-modal-header">
        <p class="cp-modal-title">{t.compareModalPre}<strong>{country.name}</strong>{t.compareModalPost}</p>
        <button class="cp-modal-close" id="cp-modal-close" aria-label="Close">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 2l12 12M14 2L2 14"/></svg>
        </button>
      </div>
      <div class="cp-modal-search-wrap">
        <input id="cp-modal-input" type="text" class="cp-modal-input" placeholder={t.typeCountryName} autocomplete="off" spellcheck="false" />
        <div class="cp-modal-dropdown" id="cp-modal-dropdown" role="listbox" hidden></div>
      </div>
    </div>
  </div>

