<script>
  const countries: {name:string; slug:string}[] =
    JSON.parse(document.getElementById('cp-countries-data')!.textContent!);

  const openBtn    = document.getElementById('cp-compare-open')    as HTMLButtonElement;
  const modal      = document.getElementById('cp-modal')           as HTMLElement;
  const closeBtn   = document.getElementById('cp-modal-close')     as HTMLButtonElement;
  const searchInput = document.getElementById('cp-modal-input')    as HTMLInputElement;
  const dropdown   = document.getElementById('cp-modal-dropdown')  as HTMLElement;

  const currentSlug = openBtn.dataset.slug ?? '';
  let activeIdx = -1;

  function openModal() {
    modal.hidden = false;
    searchInput.value = '';
    dropdown.hidden = true;
    activeIdx = -1;
    setTimeout(() => searchInput.focus(), 50);
    document.addEventListener('keydown', onEsc);
  }

  function closeModal() {
    modal.hidden = true;
    document.removeEventListener('keydown', onEsc);
  }

  function onEsc(e: KeyboardEvent) {
    if (e.key === 'Escape') closeModal();
  }

  openBtn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });

  function renderDropdown(q: string) {
    dropdown.innerHTML = '';
    activeIdx = -1;
    if (!q.trim()) { dropdown.hidden = true; return; }
    const lower = q.toLowerCase();
    const matches = countries
      .filter(c => c.slug !== currentSlug && c.name.toLowerCase().includes(lower))
      .sort((a, b) => {
        const as = a.name.toLowerCase().startsWith(lower);
        const bs = b.name.toLowerCase().startsWith(lower);
        return as === bs ? a.name.localeCompare(b.name) : as ? -1 : 1;
      })
      .slice(0, 8);
    if (!matches.length) { dropdown.hidden = true; return; }
    matches.forEach(c => {
      const div = document.createElement('div');
      div.className = 'ac-option';
      div.setAttribute('role', 'option');
      div.dataset.slug = c.slug;
      div.textContent = c.name;
      div.addEventListener('mousedown', e => { e.preventDefault(); pick(c); });
      dropdown.appendChild(div);
    });
    dropdown.hidden = false;
  }

  function pick(c: {name:string; slug:string}) {
    window.location.href = `/compare/${currentSlug}-vs-${c.slug}/`;
  }

  function setActive(idx: number) {
    const opts = dropdown.querySelectorAll<HTMLElement>('.ac-option');
    opts.forEach((o, i) => o.classList.toggle('ac-option--active', i === idx));
    activeIdx = idx;
  }

  searchInput.addEventListener('input', () => renderDropdown(searchInput.value));
  searchInput.addEventListener('blur',  () => setTimeout(() => { dropdown.hidden = true; }, 200));
  searchInput.addEventListener('focus', () => { if (searchInput.value) renderDropdown(searchInput.value); });
  searchInput.addEventListener('keydown', e => {
    const opts = dropdown.querySelectorAll<HTMLElement>('.ac-option');
    if (e.key === 'ArrowDown') { e.preventDefault(); setActive(Math.min(activeIdx + 1, opts.length - 1)); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(Math.max(activeIdx - 1, -1)); }
    else if (e.key === 'Enter' && activeIdx >= 0) {
      e.preventDefault();
      const c = countries.find(c2 => c2.slug === opts[activeIdx].dataset.slug);
      if (c) pick(c);
    } else if (e.key === 'Escape') { closeModal(); }
  });
</script>
